		odrl:action cc:Distribution,&#160;cc:DerivativeWorks
	];
	cc:legalcode &lt;http://www.elda.org/media/filer_public/2014/08/01/enduser_140312.pdf&gt;&#160;
	rdfs:seeAlso &lt;http://www.elda.org/en/services-around-lrs/distribution/licensing/&gt; .
</pre>
<h3><span id="Example_.236_ELRA_VAR"></span><span class="mw-headline" id="Example_#6_ELRA_VAR">Example #6 ELRA VAR</span></h3>
<p>This example corresponds to the ELRA VAR agreement (see the text <a rel="nofollow" class="external text" href="http://www.elra.info/IMG/pdf_VAR_140312.pdf">here</a>)
</p>
<pre>&lt;http://purl.org/ms-lod/rdflicense/elra-var&gt; 
	a                odrl:Policy&#160;;
	rdfs:label   "LANGUAGE RESOURCES VALUE-ADDED-RESELLER AGREEMENT"&#160;;
	dct:alternative   "ELRA-VAR"&#160;;
